[Unit]
Description=Deloros admin panel — управление реестром членов клуба
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=alex
WorkingDirectory=/home/alex/deloros_bot
EnvironmentFile=/home/alex/deloros_bot/.env
ExecStart=/home/alex/deloros_bot/.venv/bin/uvicorn panel.app:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
