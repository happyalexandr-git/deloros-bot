MAX_TOKEN=your_max_bot_token_from_MasterBot
# Базовый URL MAX Bot API (по умолчанию https://platform-api.max.ru — серт Let's Encrypt).
# platform-api2.max.ru требует российский УЦ Минцифры (нет в certifi).
# MAX_API_URL=https://platform-api.max.ru
OPENAI_API_KEY=your_openai_key_here
# Модель OpenAI (по умолчанию gpt-4o)
# OPENAI_MODEL=gpt-4o
# Свой OpenAI-совместимый endpoint (если не api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com/v1
TAVILY_API_KEY=your_tavily_key_here
# Прокси для OpenAI API (если нужен из РФ). MAX-транспорту прокси не нужен.
# PROXY_URL=socks5://user:pass@host:port

# --- Транспорт MAX: polling (по умолчанию) или webhook ---
# Webhook обязателен для голосовых: по long-poll MAX не присылает аудио-вложения.
# MAX_TRANSPORT=webhook
# Публичный https-адрес вебхука (проксируется NPM на srv001:MAX_WEBHOOK_PORT)
# MAX_WEBHOOK_URL=https://xn--d1acsmali.xn--p1ai/max-webhook
# Секрет (5-256 симв.) — MAX шлёт его в X-Max-Bot-Api-Secret, maxapi проверяет сам
# MAX_WEBHOOK_SECRET=
# Локальный порт webhook-сервера бота (8087 занят панелью)
# MAX_WEBHOOK_PORT=8088
# ID группового чата — узнаешь после первого запуска бота
CHAT_ID=

# --- Админ-панель (panel/) ---
ADMIN_USER=admin
ADMIN_PASSWORD=
# Секрет для подписи сессий-кук (любая длинная случайная строка)
PANEL_SECRET_KEY=
# Порт панели (слушает только в корп-сети; 8080 на srv001 занят другим сервисом)
PANEL_PORT=8087
